# Required — get these from your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key (server-only). Used by the notification outbox drain cron
# route and the employee invitation flow. Leave unset in development and these
# features will return a server configuration error.
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of this app (no trailing slash). Used as the redirect base when
# sending employee invitation emails.
NEXT_PUBLIC_SITE_URL=https://your-app-domain.com

# Shared secret expected in the `Authorization: Bearer <secret>` header on the
# /api/cron/drain-notifications endpoint. Generate a long random string and
# configure your scheduler (Vercel Cron, GitHub Actions, etc.) to send it.
CRON_SECRET=
