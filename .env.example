# Required — get these from your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key (server-only). Used by:
#   * the notification outbox drain cron route to invoke
#     drain_notification_outbox() with elevated privileges, and
#   * the admin Employees flow (src/lib/auth/invite-employee.ts) to call
#     supabase.auth.admin.inviteUserByEmail and bind the resulting auth user
#     onto the employee row.
# Leave unset in development — the cron route returns 503 and the Invite
# button surfaces a friendly error.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (no trailing slash). Used as the base for redirect links
# embedded in invitation / password-recovery emails. In Vercel set this to
# your deployment URL; for local dev use http://localhost:3000. Falls back to
# NEXT_PUBLIC_SUPABASE_URL if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret expected in the `Authorization: Bearer <secret>` header on the
# cron endpoints (drain-notifications, send-communications, run-retention-purge).
# Generate a long random string and configure your scheduler (Vercel Cron,
# GitHub Actions, etc.) to send it. All three routes are wired into vercel.json
# with the same secret.
CRON_SECRET=

# ---- External communication transports (optional) ---------------------------
# Used by /api/cron/send-communications to deliver communication_recipients
# rows via email (Resend). Leave blank to disable — recipient rows stay
# 'pending' and flush once secrets are provisioned.

# Resend: https://resend.com — RESEND_FROM must be a verified domain sender.
#
# DNS setup: the domain in RESEND_FROM (right of the @) must match the domain
# you verified in the Resend dashboard. Resend's standard setup uses a `send.`
# subdomain — e.g. RESEND_FROM="Rink Reports <noreply@send.example.com>" expects
# these four DNS records on example.com:
#   MX     send                  feedback-smtp.<region>.amazonses.com  (priority 10)
#   TXT    send                  v=spf1 include:amazonses.com ~all
#   TXT    resend._domainkey.send  <p=MIGf... value from Resend dashboard>
#   TXT    _dmarc.send           v=DMARC1; p=none;
# After saving, click "Verify DNS Records" in Resend. If you change the sending
# subdomain (or drop the `send.` prefix), update the DNS record names to match.
RESEND_API_KEY=
RESEND_FROM=

# Environment gate for outbound email. Even with a valid RESEND_API_KEY,
# delivery only happens in the production environment (VERCEL_ENV=production,
# falling back to NODE_ENV) — so a dev clone or Vercel preview that inherits
# production secrets can never email real staff. Override per environment:
#   RESEND_ENABLED=true   force-enable (e.g. staging email QA)
#   RESEND_ENABLED=false  kill switch (blocks delivery even in production)
# Leave unset for the default environment-based behavior. While delivery is
# disabled, recipient rows stay 'pending' and flush once it's allowed.
RESEND_ENABLED=

# ---- PostHog (optional, client-side) ---------------------------------------
# When set, the staff PWA forwards uncaught exceptions (via the error
# boundary's posthog.captureException call) and pageviews to PostHog.
# Leave both blank to disable — posthog-js is then never imported on the
# client, so there's no bundle or network cost. Set NEXT_PUBLIC_POSTHOG_HOST
# only if you're using EU cloud or a self-hosted instance; defaults to
# https://us.i.posthog.com.
#
# Autocapture is intentionally OFF in the provider (privacy: the app handles
# incident descriptions, employee names, and accident records). Call sites
# that want manual capture import posthog-js directly.
#
# Capture is also environment-gated (same pattern as RESEND_ENABLED): even
# with a key set, events only ship in production (VERCEL_ENV /
# NEXT_PUBLIC_VERCEL_ENV = production, falling back to NODE_ENV), so a dev
# clone or preview deployment that inherits the production key can't pollute
# production analytics. Exception messages are PII-scrubbed (emails/phones
# masked) before leaving the browser or server. Override per environment:
#   NEXT_PUBLIC_POSTHOG_ENABLED=true   force-enable (e.g. staging QA)
#   NEXT_PUBLIC_POSTHOG_ENABLED=false  kill switch (even in production)
# On Vercel, NEXT_PUBLIC_VERCEL_ENV is provided automatically when system
# environment variables are exposed (the default).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_ENABLED=
