# Required — get these from your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key (server-only). Used by the notification outbox drain cron
# route to invoke drain_notification_outbox() with elevated privileges, and by
# the admin Employees flow to invite new employees via auth.admin.*. Leave
# unset in development and dependent routes/actions will surface a clear error.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (no trailing slash). Used as the base for redirect links
# embedded in invitation / password-recovery emails. In Vercel set this to
# your deployment URL; for local dev use http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# route and the employee invitation flow. Leave unset in development and these
# features will return a server configuration error.
# Service-role key (server-only). Used by:
#   * the notification outbox drain cron route to invoke
#     drain_notification_outbox() with elevated privileges, and
#   * the employee-invite server action (src/app/admin/employees/invite-actions.ts)
#     to call supabase.auth.admin.inviteUserByEmail and bind the resulting
#     auth user onto the employee row.
# Leave unset in development — the cron route returns 503 and the Invite
# button surfaces a friendly error.
SUPABASE_SERVICE_ROLE_KEY=

# Public origin of this app (no trailing slash). Used as the redirect base
# when sending employee invitation emails so the magic link lands on
# /dashboard at your real site rather than the Supabase project URL.
# Falls back to NEXT_PUBLIC_SUPABASE_URL if unset.
NEXT_PUBLIC_SITE_URL=https://your-app-domain.com

# Shared secret expected in the `Authorization: Bearer <secret>` header on the
# /api/cron/drain-notifications endpoint. Generate a long random string and
# configure your scheduler (Vercel Cron, GitHub Actions, etc.) to send it.
CRON_SECRET=
