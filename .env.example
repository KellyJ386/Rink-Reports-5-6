# Required — get these from your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key (server-only). Used by the notification outbox drain cron
# route to invoke drain_notification_outbox() with elevated privileges, and by
# the admin Employees flow to invite new employees via auth.admin.*. Leave
# unset in development and dependent routes/actions will surface a clear error.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (no trailing slash). Used as the base for redirect links
# embedded in invitation / password-recovery emails. In Vercel set this to
# your deployment URL; for local dev use http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret expected in the `Authorization: Bearer <secret>` header on the
# /api/cron/drain-notifications endpoint. Generate a long random string and
# configure your scheduler (Vercel Cron, GitHub Actions, etc.) to send it.
CRON_SECRET=
