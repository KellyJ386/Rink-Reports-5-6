# ─────────────────────────────────────────────────────────────────────────────
# Rink Reports E2E test configuration
#
# Copy to `e2e/.env.e2e.local` (gitignored — never commit real passwords) and
# fill in. The loader (e2e/fixtures/env.ts) reads .env.e2e then .env.e2e.local;
# real shell/CI env vars always win over file values.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the environment under test. Point at staging, or run locally.
E2E_BASE_URL=https://staging.rinkreports.com

# Set to 1 to have Playwright boot `pnpm start` itself (local runs). Leave unset
# when targeting a deployed staging URL.
E2E_START_SERVER=

# ── Passwords (REQUIRED to un-skip the matching tests) ───────────────────────
# Emails default to <role>-test@rinkreports.com; override with E2E_<ROLE>_EMAIL.
E2E_ADMIN_PASSWORD=
E2E_MANAGER_PASSWORD=
E2E_SUPERVISOR_PASSWORD=
E2E_ICETECH_PASSWORD=
E2E_FRONTDESK_PASSWORD=
E2E_CONCESSIONS_PASSWORD=
E2E_JANITORIAL_PASSWORD=

# Optional email overrides (defaults shown):
# E2E_ADMIN_EMAIL=admin-test@rinkreports.com
# E2E_MANAGER_EMAIL=manager-test@rinkreports.com
# E2E_SUPERVISOR_EMAIL=supervisor-test@rinkreports.com
# E2E_ICETECH_EMAIL=icetech-test@rinkreports.com
# E2E_FRONTDESK_EMAIL=frontdesk-test@rinkreports.com
# E2E_CONCESSIONS_EMAIL=concessions-test@rinkreports.com
# E2E_JANITORIAL_EMAIL=janitorial-test@rinkreports.com

# ── Inactive account (auth: "inactive users cannot log in") ──────────────────
E2E_INACTIVE_EMAIL=inactive-test@rinkreports.com
E2E_INACTIVE_PASSWORD=

# ── Multi-tenant isolation (section 9) ───────────────────────────────────────
# A user that belongs to Facility B (the admin/* users above are Facility A).
E2E_FACILITY_B_EMAIL=facilityb-test@rinkreports.com
E2E_FACILITY_B_PASSWORD=
# A report URL that belongs to Facility B (e.g. a daily-report or incident
# detail page). Section 9 has the Facility-A user try to open it directly and
# asserts the request is denied by RLS.
E2E_FACILITY_B_REPORT_PATH=

# ── Optional: known-good config for deeper assertions ────────────────────────
# A daily-reports area+template the assigned users can submit to, used by the
# daily-report submission tests. Format: /reports/daily/<areaSlug>/<templateId>
E2E_DAILY_REPORT_PATH=
# An ice-depth layout slug the test user can submit (section 7).
E2E_ICE_DEPTH_LAYOUT_SLUG=
